# Demo Mode - Read-only, wallet gerekmez
POLYMARKET_MODE=demo

# API Base URLs (değiştirme)
GAMMA_API_URL=https://gamma-api.polymarket.com
CLOB_API_URL=https://clob.polymarket.com
DATA_API_URL=https://data-api.polymarket.com

# Full Mode için (opsiyonel - trading aktif eder)
# POLYMARKET_MODE=full
# WALLET_PRIVATE_KEY=0x...
# WALLET_ADDRESS=0x...

# Güvenlik Limitleri (Full Mode)
REQUIRE_CONFIRMATION_ABOVE_USD=100
MAX_SPREAD_TOLERANCE=0.05
MAX_SINGLE_TRADE_USD=500

# WebSocket
WS_URL=wss://ws-subscriptions-clob.polymarket.com/ws/market
WS_RECONNECT_DELAY_MS=3000
WS_MAX_RECONNECT_ATTEMPTS=5

# ================================================================
# POLYMARKET BOT — ORTAM DEĞİŞKENLERİ
# ================================================================
# 
# GÜVENLİ KURULUM:
#   1. Bu dosyayı KOPYALAMA — sadece örnek gösterir
#   2. Secrets için /root/.polymarket_secrets oluştur (chmod 600)
#   3. Non-sensitive ayarlar için /opt/polymarket/bot/.env kullan
#
# SECRETS DOSYASI (/root/.polymarket_secrets, chmod 600):
# ================================================================
WALLET_NAME=ozibot
WALLET_ADDRESS=0xYOUR_WALLET_ADDRESS
PRIVATE_KEY=0xYOUR_PRIVATE_KEY_HERE

POLYMARKET_API_KEY=your_api_key
POLYMARKET_API_SECRET=your_api_secret
POLYMARKET_API_PASSPHRASE=your_passphrase

# NON-SENSITIVE (.env, proje klasöründe kalabilir):
# ================================================================
MODE=live
LOG_LEVEL=info
DB_PATH=./data/observer.db

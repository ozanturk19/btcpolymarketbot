# Polymarket BTC Bot - Ortam Değişkenleri
# Bu dosyayı .env olarak kopyala ve doldur

# Canlı trading için (şimdilik boş bırak — paper mode için gerekmiyor)
PRIVATE_KEY=
POLYMARKET_API_KEY=
POLYMARKET_API_SECRET=
POLYMARKET_API_PASSPHRASE=

# Ayarlar
MODE=paper          # observe | paper | live
LOG_LEVEL=info      # debug | info | warn
DB_PATH=./data/observer.db
